# Set the port on which SwaftHub will run on.
# PORT=2345

# Choose whether or not to use the Bare Server.
# Set to true or leave it alone if using Vercel.
# BARE="false"

# Choose whether or not you want to enable MASQR.
# Separate licensing server required for this to work.
# https://github.com/titaniumnetwork-dev/MasqrProject
# MASQR="false"

# CDN Configuration - Set your assets CDN URL
# ASSETS_CDN="https://swafthub-assets.pages.dev"

# Apps JSON URL - Set your apps/games data source
# APPS_JSON_URL="https://swafthub-apps.pages.dev/apps.json"
